# Development environment variables for MiniWall

# Application
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/miniwall-dev
MONGODB_INITDB_ROOT_USERNAME=admin
MONGODB_INITDB_ROOT_PASSWORD=admin123
MONGO_INITDB_DATABASE=miniwall-dev

# Auth Server
AUTH_SERVER_URL=http://localhost:4000
JWT_SECRET=dev-jwt-secret-key-change-in-production

# OAuth2
OAUTH2_CLIENT_ID=miniwall-client
OAUTH2_CLIENT_SECRET=miniwall-client-secret
